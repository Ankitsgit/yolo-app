# frontend/.env
# 🧠 LEARN: Vite requires VITE_ prefix (not REACT_APP_)
# Without this prefix, the variable is invisible to your code

# During development — points to your local backend
VITE_API_URL=http://localhost:5000

# During production — you'll update this to Render URL
# VITE_API_URL=https://yolo-backend.onrender.com